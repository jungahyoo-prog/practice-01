{
  "name": "practice-01",
  "version": "0.1.0",
  "private": true,
  "description": "업무 대시보드 desktop wrapper",
  "author": "Dreamus",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "set NEXT_PUBLIC_FLO_ENV=dev&& next dev",
    "qa": "set NEXT_PUBLIC_FLO_ENV=qa&& next dev",
    "prod": "set NEXT_PUBLIC_FLO_ENV=prod&& next dev",
    "build": "set NEXT_PUBLIC_FLO_ENV=dev&& next build",
    "build:dev": "set NEXT_PUBLIC_FLO_ENV=dev&& next build",
    "build:qa": "set NEXT_PUBLIC_FLO_ENV=qa&& next build",
    "build:prod": "set NEXT_PUBLIC_FLO_ENV=prod&& next build",
    "start": "next start",
    "desktop:web": "set NEXT_PUBLIC_FLO_ENV=dev&& next build --no-lint",
    "desktop:start": "npm run desktop:web && electron .",
    "desktop:dist": "npm run desktop:web && electron-builder --win nsis",
    "desktop:web:mac": "NEXT_PUBLIC_FLO_ENV=dev next build --no-lint",
    "desktop:dist:mac": "npm run desktop:web:mac && electron-builder --mac dmg zip",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "container:build": "bash container-build.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.13.6",
    "crypto-js": "^4.2.0",
    "mixpanel-browser": "^2.74.0",
    "next": "^15.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "serve-handler": "^6.1.7",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "postcss": "^8.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "supabase": "^2.85.0",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.vibeflo.practice01",
    "productName": "업무 대시보드",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "out",
        "to": "out"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "executableName": "업무 대시보드",
      "target": [
        "nsis"
      ],
      "artifactName": "업무-대시보드-설치-${version}.${ext}"
    },
    "mac": {
      "identity": null,
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "업무-대시보드-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "업무 대시보드"
    }
  }
}
